# ARTES-BUHO_HTML — Cascada IA (adaptada de ARTES-BUHO_RAMON)
# Copiar a .env (gitignored). Cuanto mas rellenes, mas robusta la cascada.
# TODAS son OPCIONALES: si falta clave, la cascada salta al siguiente nivel.

# === Nivel 1: Ollama local (GRATIS, preferido — RTX 4070 qwen2.5:14b) ===
PC_OLLAMA_URL=http://localhost:11434
PC_OLLAMA_MODEL=qwen2.5:14b

# === Nivel 2: Groq (14.400 req/dia free, rapidisimo) ===
# https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# === Nivel 3: OpenRouter (50 req/dia con modelos :free) ===
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-120b:free

# === Nivel 4: Cerebras (14.400 req/dia, qwen-3-235b) ===
# https://cloud.cerebras.ai
CEREBRAS_API_KEY=
CEREBRAS_MODEL=qwen-3-235b-a22b-instruct-2507

# === Nivel 5: Gemini (1.500 req/dia) ===
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# === Nivel 6: VPS Ollama (ultima red, qwen2.5:1.5b siempre-on) ===
OLLAMA_URL=
OLLAMA_MODEL=qwen2.5:1.5b
